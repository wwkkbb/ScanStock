{
  "name": "cashier-app-wrapper",
  "displayName": "CashierApp",
  "version": "1.0.0",
  "description": "Cordova Android wrapper for CashierApp",
  "main": "index.js",
  "scripts": {
    "cordova": "cordova",
    "sync:www": "powershell -NoProfile -ExecutionPolicy Bypass -File ..\\scripts\\sync-apk-www.ps1",
    "platform:add:android": "cordova platform add android",
    "prebuild:android": "npm run sync:www",
    "build:android": "cordova build android"
  },
  "keywords": [
    "ecosystem:cordova"
  ],
  "author": "Local Build",
  "license": "Apache-2.0",
  "devDependencies": {
    "cordova-plugin-android-permissions": "^1.1.5",
    "cordova-plugin-file": "^8.0.0"
  },
  "cordova": {
    "plugins": {
      "cordova-plugin-file": {},
      "cordova-plugin-android-permissions": {}
    }
  }
}